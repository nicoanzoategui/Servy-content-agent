# Copiá este archivo a .env.local y completá valores (nunca subas .env.local).

# Google AI (Gemini)
GOOGLE_AI_API_KEY=

# Anthropic — opcional
ANTHROPIC_API_KEY=

# fal.ai — imágenes (también acepta FAL_KEY)
FAL_API_KEY=
FAL_KEY=

# URL pública de la app (links en emails, Twilio)
APP_URL=
NEXT_PUBLIC_APP_URL=http://localhost:3088

# Meta Graph API
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_PAGE_ID=
META_IG_ACCOUNT_ID=
META_GRAPH_API_VERSION=v21.0

# Base de WhatsApp para /track (se copian query UTM encima)
# Ej: https://wa.me/5491100000000?text=Hola
WHATSAPP_REDIRECT_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Notificaciones
RESEND_API_KEY=
RESEND_FROM=Servy Content <onboarding@resend.dev>
APPROVAL_NOTIFY_EMAIL=
APPROVAL_LINK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_TO=

NEXTAUTH_SECRET=

# Crons Vercel — en producción, /api/cron/* puede exigir Bearer CRON_SECRET
CRON_SECRET=

# Fase 6 — Meta Ads (cuando aplique)
META_AD_ACCOUNT_ID=
META_SYSTEM_USER_TOKEN=
